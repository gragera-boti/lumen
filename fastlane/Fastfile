default_platform(:ios)

platform :ios do
  private_lane :api_key do
    app_store_connect_api_key(
      key_id: "54GDX3ZRZU",
      issuer_id: "8da56372-26b9-474a-a426-c691338169a5",
      key_filepath: File.expand_path("~/.private_keys/AuthKey_54GDX3ZRZU.p8")
    )
  end

  desc "Run automated tests"
  lane :tests do
    scan(
      scheme: "Lumen",
      clean: true,
      devices: ["iPhone 17 Pro"] # Fallbacking simulators often destabilizes xcodebuild test runner connections
    )
  end

  desc "Build and upload app to TestFlight"
  lane :upload_testflight do
    tests
    api_key

    build_app(
      scheme: "Lumen",
      configuration: "Release",
      destination: "generic/platform=iOS",
      export_options: "./ExportOptions.plist",
      xcargs: "-allowProvisioningUpdates"
    )

    pilot(
      skip_waiting_for_build_processing: false,
      skip_submission: false,
      groups: ["Internal Testers", "Dev Team"]
    )

    version = lane_context[SharedValues::VERSION_NUMBER]
    build = lane_context[SharedValues::BUILD_NUMBER]
    tag_name = version && build ? "v#{version}-#{build}" : "v_#{Time.now.strftime('%Y%m%d%H%M')}"
    
    add_git_tag(
      grouping: "testflight",
      tag: "testflight/#{tag_name}"
    )
    push_to_git_remote(tags: true)
  end

  desc "Assign testflight groups"
  lane :assign_groups do
    api_key
    pilot(
      app_identifier: "com.gragera.lumen",
      app_platform: "ios",
      groups: ["Internal Testers", "Dev Team"],
      distribute_only: true,
      build_number: "11"
    )
  end

  desc "Upload metadata to App Store Connect"
  lane :upload_metadata do
    api_key
    deliver(
      app_identifier: "com.gragera.lumen",
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Submit app for review"
  lane :submit_for_review do
    tests
    api_key
    deliver(
      app_identifier: "com.gragera.lumen",
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end
