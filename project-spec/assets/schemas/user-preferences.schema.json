{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/user-preferences.schema.json",
  "title": "UserPreferences",
  "type": "object",
  "required": [
    "locale",
    "tonePreset",
    "gentleMode",
    "selectedCategoryIds",
    "includeSensitiveTopics",
    "contentFilters",
    "reminders",
    "voice",
    "themeId",
    "analyticsOptOut"
  ],
  "properties": {
    "locale": {
      "type": "string"
    },
    "tonePreset": {
      "type": "string",
      "enum": [
        "GENTLE",
        "NEUTRAL",
        "ENERGETIC",
        "SPIRITUAL"
      ]
    },
    "gentleMode": {
      "type": "boolean"
    },
    "selectedCategoryIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "includeSensitiveTopics": {
      "type": "boolean"
    },
    "contentFilters": {
      "type": "object",
      "required": [
        "spiritual",
        "manifestation",
        "bodyFocus"
      ],
      "properties": {
        "spiritual": {
          "type": "boolean"
        },
        "manifestation": {
          "type": "boolean"
        },
        "bodyFocus": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "reminders": {
      "type": "object",
      "required": [
        "enabled",
        "countPerDay",
        "windowStart",
        "windowEnd",
        "quietStart",
        "quietEnd"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "countPerDay": {
          "type": "integer",
          "minimum": 0,
          "maximum": 12
        },
        "windowStart": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "windowEnd": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "quietStart": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "quietEnd": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        }
      },
      "additionalProperties": false
    },
    "voice": {
      "type": "object",
      "required": [
        "language",
        "voiceId",
        "rate"
      ],
      "properties": {
        "language": {
          "type": "string"
        },
        "voiceId": {
          "type": "string"
        },
        "rate": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 1.5
        }
      },
      "additionalProperties": false
    },
    "themeId": {
      "type": [
        "string",
        "null"
      ]
    },
    "analyticsOptOut": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
