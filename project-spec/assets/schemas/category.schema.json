{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/category.schema.json",
  "title": "Category",
  "type": "object",
  "required": [
    "id",
    "locale",
    "name",
    "description",
    "icon",
    "isPremium",
    "isSensitive",
    "sortOrder",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "locale": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "icon": {
      "type": "string",
      "description": "SF Symbol name or asset key"
    },
    "isPremium": {
      "type": "boolean"
    },
    "isSensitive": {
      "type": "boolean"
    },
    "sortOrder": {
      "type": "integer"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
